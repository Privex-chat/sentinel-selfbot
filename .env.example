# ── Core ─────────────────────────────────────────────────────────────────────
# REQUIRES RESTART to change (not hot-reloadable via API):

DISCORD_TOKEN=your_account_token_here
API_PORT=48923

# API_AUTH_TOKEN guards every /api/* endpoint. Clients must send it as:
#   Authorization: Bearer <token>
# The selfbot uses constant-time comparison (crypto.timingSafeEqual) so partial
# guesses can't leak via timing. Generate at least 32 random chars — anything
# you'd use as a password will do.
API_AUTH_TOKEN=generate_a_random_string_here

DB_PATH=./data/sentinel.db
LOG_LEVEL=info
RANDOM_JITTER=false

# ── API CORS allowlist ───────────────────────────────────────────────────────
# Comma-separated list of origins that the API will accept cross-origin
# requests from. Unset = ships with a safe default allowlist (hosted Vercel
# panel + the two common localhost dev ports below).
#   Default: https://sentinel-panel.vercel.app, http://localhost:5173, http://localhost:3000
# A literal "*" reflects ANY origin — only safe behind your own reverse-proxy
# auth, never on a public deployment.
# REQUIRES RESTART to change.
API_CORS_ORIGINS=

# ── Randomisation ─────────────────────────────────────────────────────────────
#
#   RANDOM_JITTER=true   Adds ±20% jitter to every polling interval so requests
#                        don't fire on a perfectly predictable schedule.
#                        Also randomises the browser/OS fingerprint in the Discord
#                        gateway IDENTIFY payload, affecting REST headers too.
#                        Recommended for Railway / cloud deployments.
#

# ── Database mode ─────────────────────────────────────────────────────────────
#
#   local       – SQLite only. Default. Use on a home server / VPS with a
#                 persistent disk. Supabase vars below are not needed.
#
#   local+cloud – SQLite is the live database; Supabase receives a mirror copy
#                 on the interval below. Good for self-hosted + cloud backup.
#                 ("both" is accepted as a legacy alias for this mode.)
#
#   cloud       – For Railway / Render / Fly.io and any host that wipes the
#                 filesystem on redeploy. On startup, Sentinel pulls all data
#                 from Supabase into a fresh local SQLite before connecting to
#                 Discord. Supabase is the permanent store.
#                 Recommended: set SUPABASE_SYNC_INTERVAL_MS=30000 so you
#                 lose at most 30 seconds of data if the container is killed.
#
# REQUIRES RESTART to change.
#
DB_MODE=local

# ─────────────────────────────────────────────────────────────────────────────
# All variables below this line can be changed at runtime via the API
# (PATCH /api/config) without restarting the selfbot.
# ─────────────────────────────────────────────────────────────────────────────

# ── Polling intervals ─────────────────────────────────────────────────────────
#
# PROFILE_POLL_INTERVAL_MS drives the consolidated target-profile poller —
# one Discord REST call per target per cycle to /users/{id}/profile, which
# fans out into three in-process diffs:
#   - profile snapshot     → PROFILE_UPDATE / AVATAR_CHANGE / USERNAME_CHANGE
#   - mutual guild list    → SERVER_JOIN / SERVER_LEAVE
#   - connected accounts   → ACCOUNT_CONNECTED / ACCOUNT_DISCONNECTED
# After 5 consecutive failures for a target the selfbot fires a critical
# webhook and halves cadence for that target until the next success.
#
# Minimum values (validated by setRuntimeConfig + at startup):
#   PROFILE_POLL_INTERVAL_MS   ≥ 60_000   (1 min)
#   STATUS_POLL_INTERVAL_MS    ≥ 30_000   (30 s)
#   DAILY_SUMMARY_INTERVAL_MS  ≥ 300_000  (5 min)
#
PROFILE_POLL_INTERVAL_MS=300000
STATUS_POLL_INTERVAL_MS=120000
DAILY_SUMMARY_INTERVAL_MS=3600000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required when DB_MODE=local+cloud or DB_MODE=cloud.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Runtime-config encryption ────────────────────────────────────────────────
# 32-byte (256-bit) base64-encoded key used to AES-256-GCM encrypt sensitive
# runtime_config values (DISCORD_TOKEN, AI_API_KEY, SUPABASE_SERVICE_KEY,
# webhook URLs) before they are written to SQLite or synced to Supabase.
#
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Treat this like any other secret — losing it makes encrypted values
# unreadable. Rotating it requires re-writing every encrypted row through
# PATCH /api/config so the new key takes effect.
#
# Optional in DB_MODE=local. Strongly recommended in local+cloud and cloud.
SENTINEL_DATA_KEY=

# How often (ms) to push SQLite data to Supabase.
# local+cloud default: 300000 (5 min)
# cloud recommended:    30000 (30 sec) — limits data loss window on crash/redeploy
SUPABASE_SYNC_INTERVAL_MS=300000

# ── AI Provider ───────────────────────────────────────────────────────────────
#
# Valid values (server-side validated — any other string returns HTTP 400 from
# PATCH /api/config, or fails at startup):
#
#   AI_PROVIDER=none      Disables all AI analysis. Default.
#
#   AI_PROVIDER=gemini    Google Gemini API — RECOMMENDED FREE OPTION
#                         Free tier: 15 RPM and 1 million tokens/day via Google AI Studio.
#                         Concurrent analyser calls are serialised through a
#                         module-level mutex so the 15 RPM cap isn't blown
#                         when multiple analyses tick simultaneously.
#                         Get a free key at: https://aistudio.google.com
#                         Recommended model: gemini-2.5-flash
#
#   AI_PROVIDER=ollama    Local LLM via Ollama (free, private, your PC must stay on)
#                         Expose via ngrok: ngrok http 11434 --host-header="localhost:11434"
#                         Then set AI_BASE_URL to the ngrok https URL + /v1
#
#   AI_PROVIDER=openai    OpenAI API (pay-per-token)
#
#   AI_PROVIDER=anthropic Anthropic Claude API (pay-per-token)
#
# ── Gemini (recommended free setup) ──────────────────────────────────────────
# AI_PROVIDER=gemini
# AI_MODEL=gemini-2.5-flash
# AI_API_KEY=your_google_ai_studio_key_here
#
# ── Ollama (local, exposed via ngrok) ────────────────────────────────────────
# AI_PROVIDER=ollama
# AI_MODEL=llama3.2
# AI_BASE_URL=https://your-static-domain.ngrok-free.app/v1
# AI_API_KEY=  (leave blank for Ollama)
#
# ── OpenAI ───────────────────────────────────────────────────────────────────
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=sk-...
# AI_BASE_URL=https://api.openai.com/v1
#
# ── Anthropic ────────────────────────────────────────────────────────────────
# AI_PROVIDER=anthropic
# AI_MODEL=claude-3-5-haiku-20241022
# AI_API_KEY=sk-ant-...
#
AI_PROVIDER=none
AI_MODEL=gemini-2.5-flash
AI_API_KEY=
AI_BASE_URL=http://localhost:11434/v1
AI_ANALYSIS_INTERVAL_MS=86400000
AI_CATEGORIZATION_BATCH_SIZE=50

# ── Backfill ──────────────────────────────────────────────────────────────────
#
# BACKFILL_ENABLED parses with strict equality: ONLY the literal string "true"
# enables backfill. Anything else ("True", "1", "yes", "off", unset → empty
# string, etc.) is treated as disabled.
# Unset env var defaults to "true" via the (env ?? "true") fallback.
#
# Backfill is hard-cancelled at the next loop checkpoint when a target is
# removed mid-run — no FK-failing inserts after the targets row is deleted.
#
BACKFILL_ENABLED=true
BACKFILL_MAX_DAYS=90
BACKFILL_MAX_MESSAGES_PER_CHANNEL=5000

# ── Alerts ────────────────────────────────────────────────────────────────────
#
# ALERT_WEBHOOK_URL    — Discord webhook for normal alert notifications.
# CRITICAL_WEBHOOK_URL — Discord webhook for critical system errors only
#                        (token invalidation, auth failures, gateway errors).
#                        Can be the same URL as ALERT_WEBHOOK_URL, or a
#                        separate high-priority channel. Leave blank to disable.
#
ALERT_WEBHOOK_URL=
CRITICAL_WEBHOOK_URL=

# Digest mode batches alerts into a single SSE event (`ALERT_DIGEST`) every
# ALERT_DIGEST_INTERVAL_MS for the dashboard live feed. **Webhook delivery is
# always immediate per real event** — turning digest mode ON does NOT change
# the webhook behaviour. Earlier versions double-fired (immediate + aggregated
# webhook); that was removed in the API hardening pass.
ALERT_DIGEST_MODE=false
ALERT_DIGEST_INTERVAL_MS=900000

# Auto-suppress an alert rule after it fires this many times in 24 hours.
# The rule emits an ALERT_SUPPRESSED SSE event when suppression kicks in.
ALERT_FATIGUE_THRESHOLD=20

# ── Daily Briefs ──────────────────────────────────────────────────────────────
# Time of day (HH:MM, UTC) to generate AI-powered daily briefs per target.
# Format is validated — anything other than HH:MM with 00:00–23:59 ranges is
# rejected at startup (and by PATCH /api/config with HTTP 400).
# Requires AI_PROVIDER != none.
# The day-of-week and time labels INSIDE each brief are rendered in the
# target's own timezone (targets.timezone, default UTC) — set per target with
# $tz or via POST/PATCH /api/targets.
BRIEF_GENERATION_TIME=07:00
